<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>


<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
   <center>
      <BorderPane prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <center>
            <VBox fx:id="welcome_screen" alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="20.0" BorderPane.alignment="TOP_CENTER">
               <children>
                  <Label text="Benvenuto!">
                     <font>
                        <Font name="Hack Bold" size="40.0" />
                     </font>
                  </Label>
                  <Button fx:id="start" mnemonicParsing="false" text="Inizia!">
                     <font>
                        <Font name="Adwaita Mono" size="16.0" />
                     </font>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </VBox>
         </center>
      </BorderPane>
   </center>
   <bottom>
      <ToolBar nodeOrientation="RIGHT_TO_LEFT" prefHeight="40.0" prefWidth="200.0" style="-fx-border-color: lightgrey; -fx-background-color: gainsboro; -fx-border-insets: 0;" BorderPane.alignment="BOTTOM_LEFT">
        <items>
          <Button mnemonicParsing="false" style="-fx-background-color: orangered;" text="Close" />
            <Button mnemonicParsing="false" style="-fx-background-color: lightgreen;" text="Home">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Button>
        </items>
         <BorderPane.margin>
