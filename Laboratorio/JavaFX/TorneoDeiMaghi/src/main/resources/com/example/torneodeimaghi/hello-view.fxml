<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="700.0" prefWidth="900.0" style="-fx-background-image: url('@imagess/wall.jpg'); -fx-background-size: cover; -fx-background-position: center center;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.torneodeimaghi.HelloController">
   <children>
      <VBox alignment="CENTER" spacing="20.0" StackPane.alignment="CENTER">
         <children>
            <Label style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #ffffff; -fx-effect: dropshadow( gaussian , rgba(0,0,0,0.8) , 4,0,0,1 );" text="Arena dei Maghi" />
            <Label fx:id="logLabel" alignment="CENTER" minHeight="100.0" prefWidth="700.0" style="-fx-background-color: rgba(0,0,0,0.7); -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 15; -fx-background-radius: 10; -fx-font-weight: bold;" text="Inizia il torneo" textAlignment="CENTER" wrapText="true" />
            <HBox fx:id="arenaContainer" alignment="CENTER" spacing="40.0">
               <VBox.margin>
                  <Insets bottom="20.0" top="20.0" />
               </VBox.margin></HBox>
            <HBox alignment="CENTER" spacing="30.0">
               <children>
                  <Button fx:id="nextTurnBtn" mnemonicParsing="false" onAction="#onNextTurn" style="-fx-background-color: #3c52d9; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 12 30;" text="Prossimo Turno" />
                  <Button fx:id="resetBtn" mnemonicParsing="false" onAction="#onReset" style="-fx-background-color: #d93c3c; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 12 30;" text="Resetta Torneo" />
               </children>
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </HBox>
         </children>
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
      </VBox>
   </children>
</StackPane>
